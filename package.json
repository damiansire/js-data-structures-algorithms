{
  "name": "js-data-structures-algorithms",
  "version": "1.0.0",
  "description": "Implementaciones de estructuras de datos y algoritmos clásicos en JavaScript para estudio y referencia.",
  "private": true,
  "keywords": [
    "algorithms",
    "data-structures",
    "javascript",
    "jest"
  ],
  "scripts": {
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest",
    "coverage": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "test:metrics": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --coverage --json --outputFile=test-results.json",
    "update-metrics": "node scripts/update-metrics.mjs",
    "check-metrics": "node scripts/update-metrics.mjs --check",
    "benchmark": "node benchmarks/index.js",
    "lint": "eslint . --ext .js,.mjs,.cjs",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/damiansire/js-data-structures-algorithms.git"
  },
  "author": "Damian Sire",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "bugs": {
    "url": "https://github.com/damiansire/js-data-structures-algorithms/issues"
  },
  "homepage": "https://github.com/damiansire/js-data-structures-algorithms#readme",
  "devDependencies": {
    "cross-env": "^10.1.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.0"
  }
}
